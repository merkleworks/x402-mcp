{
  "name": "x402-mcp",
  "version": "0.1.1",
  "description": "MCP server enabling AI agents to call payment-gated HTTP APIs using the x402 protocol",
  "type": "module",
  "main": "./dist/server.js",
  "bin": {
    "x402-mcp": "./dist/server.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "mcp.json",
    ".well-known",
    "examples"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-tools",
    "agent-tools",
    "micropayments",
    "x402"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/merkleworks/x402-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/merkleworks/x402-mcp/issues"
  },
  "homepage": "https://github.com/merkleworks/x402-mcp#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
